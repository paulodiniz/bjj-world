{
  "nodes": [
    {"id": "standing", "name": "Standing", "type": "position", "description": "Both athletes on their feet. Starting state for most matches and target for technical standups."},
    {"id": "closed_guard", "name": "Closed Guard", "type": "position", "description": "Bottom player's legs locked around opponent's waist. Foundational guard with high submission threat."},
    {"id": "open_guard", "name": "Open Guard", "type": "position", "description": "Bottom player's legs are open and active but not locked. Transitional guard state with many sub-varieties."},
    {"id": "half_guard", "name": "Half Guard", "type": "position", "description": "Bottom player controls one of the top player's legs between their own. Classic transitional position."},
    {"id": "side_control", "name": "Side Control", "type": "position", "description": "Top player lies perpendicular across bottom player's torso, controlling with hip and shoulder pressure."},
    {"id": "north_south", "name": "North South", "type": "position", "description": "Top player faces opposite direction across bottom player's chest, controlling head and hips."},
    {"id": "mount", "name": "Mount", "type": "position", "description": "Top player straddles bottom player's torso sitting on their hips. High-percentage dominant position."},
    {"id": "technical_mount", "name": "Technical Mount", "type": "position", "description": "S-mount variation where top player's leg is over opponent's arm, isolating the limb for attacks."},
    {"id": "back_control", "name": "Back Control", "type": "position", "description": "Top player behind opponent with hooks in and seatbelt grip. Highest-value position in BJJ."},
    {"id": "turtle", "name": "Turtle", "type": "position", "description": "Defender on all fours, protecting neck and back. Transitional defensive position."},
    {"id": "butterfly_guard", "name": "Butterfly Guard", "type": "position", "description": "Bottom player uses both feet as hooks inside opponent's inner thighs. Mobile and sweeping guard."},
    {"id": "deep_half_guard", "name": "Deep Half Guard", "type": "position", "description": "Bottom player entirely beneath opponent's body with full leg entanglement, head under the hips."},
    {"id": "de_la_riva_guard", "name": "De La Riva Guard", "type": "position", "description": "Bottom player hooks one leg around the outside of opponent's lead leg with foot on hip. Long-range guard."},
    {"id": "x_guard", "name": "X-Guard", "type": "position", "description": "Bottom player under opponent with both hooks beneath opponent's hips, controlling both legs."},
    {"id": "knee_on_belly", "name": "Knee on Belly", "type": "position", "description": "Top player's knee pressed on bottom player's abdomen with an upright base. Transitional pressure position."},
    {"id": "spider_guard", "name": "Spider Guard", "type": "position", "description": "Bottom player controls both sleeves and places feet on opponent's biceps. Long-range grip-based guard."},
    {"id": "rear_naked_choke", "name": "Rear Naked Choke", "type": "submission", "description": "Choking arm around opponent's neck, other arm bracing behind head. Primary submission from back control."},
    {"id": "triangle_choke", "name": "Triangle Choke", "type": "submission", "description": "Legs triangled around opponent's neck and one arm, cutting off carotid arteries. Versatile strangle."},
    {"id": "armbar", "name": "Armbar", "type": "submission", "description": "Elbow joint hyperextended by controlling the arm and bridging hips. Available from multiple positions."},
    {"id": "omoplata", "name": "Omoplata", "type": "submission", "description": "Shoulder joint locked by trapping opponent's arm with the legs and rotating the hip."},
    {"id": "kimura", "name": "Kimura", "type": "submission", "description": "Figure-four grip on opponent's arm with wrist bent behind the back. Available from many positions."},
    {"id": "americana", "name": "Americana", "type": "submission", "description": "Figure-four wrist lock with arm bent at low angle on the mat. Most common from side control and mount."},
    {"id": "guillotine", "name": "Guillotine", "type": "submission", "description": "Arm around opponent's neck applying pressure on windpipe or carotid arteries. Available standing and guard."},
    {"id": "darce_choke", "name": "D'Arce Choke", "type": "submission", "description": "Figure-four arm triangle choke with arm threaded under neck. Typically applied from top positions."},
    {"id": "bow_and_arrow_choke", "name": "Bow and Arrow Choke", "type": "submission", "description": "Collar choke with cross-collar grip and belt or leg control. Primary gi submission from back control."},
    {"id": "ankle_lock", "name": "Ankle Lock", "type": "submission", "description": "Straight heel pressure on ankle joint using body as lever. Foot lock targeting the ankle ligaments."},
    {"id": "heel_hook", "name": "Heel Hook", "type": "submission", "description": "Rotational knee attack by controlling the heel and twisting. High-percentage leg lock in modern BJJ."},
    {"id": "scissor_sweep", "name": "Scissor Sweep", "type": "sweep", "description": "Bottom player scissors legs to topple opponent from closed guard using collar and sleeve grips."},
    {"id": "hip_bump_sweep", "name": "Hip Bump Sweep", "type": "sweep", "description": "Sit-up sweep from closed guard using hip explosion to roll opponent over. Sets up kimura if blocked."},
    {"id": "butterfly_sweep", "name": "Butterfly Sweep", "type": "sweep", "description": "Lifting sweep using butterfly hooks and an underhook to toss opponent to the side."},
    {"id": "x_guard_sweep", "name": "X-Guard Sweep", "type": "sweep", "description": "Sweep from x-guard lifting opponent with both hooks and dumping them to the side."},
    {"id": "flower_sweep", "name": "Flower Sweep", "type": "sweep", "description": "Pendulum sweep from closed guard using cross-collar grip and ankle control to roll opponent."},
    {"id": "torreando_pass", "name": "Torreando Pass", "type": "guard_pass", "description": "Speed pass that controls both knees and moves the hips around the guard. Primarily from open guard."},
    {"id": "knee_slice_pass", "name": "Knee Slice Pass", "type": "guard_pass", "description": "Pass by threading knee between opponent's legs and using hip pressure to cut through."},
    {"id": "double_under_pass", "name": "Double Under Pass", "type": "guard_pass", "description": "Stacking pass by controlling both legs under the arms and passing with bodyweight."},
    {"id": "over_under_pass", "name": "Over Under Pass", "type": "guard_pass", "description": "Pass controlling one leg over the shoulder and one under, using hip pressure to clear guard."},
    {"id": "leg_drag_pass", "name": "Leg Drag Pass", "type": "guard_pass", "description": "Pass by dragging opponent's top leg across the body and establishing side control."},
    {"id": "double_leg_takedown", "name": "Double Leg Takedown", "type": "takedown", "description": "Shooting to both legs and driving through opponent to bring them down. Fundamental wrestling takedown."},
    {"id": "single_leg_takedown", "name": "Single Leg Takedown", "type": "takedown", "description": "Securing one leg and using trips, lifts, or drives to take opponent down. Versatile wrestling takedown."},
    {"id": "judo_throw", "name": "Judo Throw", "type": "takedown", "description": "Hip-based or shoulder-based throw using kuzushi, tsukuri, and kake. Covers ippon seoi nage, o-goshi, etc."}
  ],
